# LiteLLM Pulse configuration
# Copy this file to .env and adjust values as needed.
# All settings can also be passed as CLI arguments or Docker environment variables.

LITELLM_PULSE_METRICS_URL=http://litellm:4000/metrics/
LITELLM_PULSE_SCRAPE_INTERVAL=60
LITELLM_PULSE_PORT=8000
LITELLM_PULSE_HOST=0.0.0.0
LITELLM_PULSE_VERIFY_SSL=false
LITELLM_PULSE_SCRAPE_TIMEOUT=30
LITELLM_PULSE_LOG_LEVEL=info
LITELLM_PULSE_DB_PATH=./data/litellm_pulse.db
LITELLM_PULSE_DB_RETENTION_DAYS=90
LITELLM_PULSE_HISTORY_SIZE=168
LITELLM_PULSE_TIMEZONE=UTC
# LITELLM_PULSE_METRICS_API_KEY=sk-your-litellm-api-key
